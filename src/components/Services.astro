---
import { Picture } from 'astro:assets';
import { services } from '../data/services';
import { images } from '../data/images';
---

<section class="section" id="services">
  <div class="shell">
    <p class="eyebrow reveal">What we do</p>
    <h2 class="reveal">Whatever moves, we move it.</h2>
    <p class="lede reveal">
      A guest, a crew, an instrument, a patient — we plan it, drive it and stay
      reachable until it's done.
    </p>

    <div class="cards">
      {
        services.map((s) =>
          s.id === 'airport' ? (
            <article class="card card-img reveal">
              <div class="card-header">
                <Picture
                  src={images.airport.card.image}
                  alt={images.airport.card.alt}
                  widths={[400, 700, 1000].filter(
                    (w) => w <= images.airport.card.image.width
                  )}
                  sizes="(max-width: 640px) 100vw, (max-width: 940px) 50vw, 380px"
                  formats={['avif', 'webp']}
                  fallbackFormat="jpg"
                  loading="lazy"
                  decoding="async"
                  style={`object-position:${images.airport.card.focal}`}
                />
              </div>
              <div class="card-body">
                <svg viewBox="0 0 24 24" aria-hidden="true" set:html={s.icon} />
                <h3>{s.title}</h3>
                <p>{s.text}</p>
                <button
                  class="card-gallery"
                  type="button"
                  data-gallery="airport"
                  aria-label={`View ${s.title} gallery`}
                >
                  View gallery
                </button>
              </div>
            </article>
          ) : (
            <article class="card reveal">
              <svg viewBox="0 0 24 24" aria-hidden="true" set:html={s.icon} />
              <h3>{s.title}</h3>
              <p>{s.text}</p>
            </article>
          )
        )
      }
    </div>
  </div>
</section>

<style>
  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--hairline);
    border: 1px solid var(--hairline);
    margin-top: 3rem;
  }
  .card {
    background: var(--ink);
    padding: 2.2rem 1.9rem;
    position: relative;
    transition: background 0.3s;
  }
  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 1.9rem;
    width: 0;
    height: 2px;
    background: var(--gold);
    transition: width 0.35s ease;
    z-index: 1;
  }
  .card:hover {
    background: var(--graphite);
  }
  .card:hover::before {
    width: 44px;
  }
  .card svg {
    width: 26px;
    height: 26px;
    stroke: var(--gold);
    fill: none;
    stroke-width: 1.1;
    margin-bottom: 1.3rem;
  }
  .card h3 {
    font-size: 1.45rem;
    margin-bottom: 0.7rem;
  }
  .card p {
    font-size: 15px;
    color: var(--stone);
  }

  /* Airport card: image header above the usual icon/title/copy body. */
  .card-img {
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .card-header {
    aspect-ratio: 16/10;
    overflow: hidden;
    position: relative;
  }
  .card-header :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .card-img:hover .card-header :global(img) {
    transform: scale(1.045);
  }
  .card-header::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 10, 11, 0.05) 55%,
      rgba(10, 10, 11, 0.55) 100%
    );
    pointer-events: none;
  }
  .card-body {
    padding: 2.2rem 1.9rem;
  }
  .card-gallery {
    margin-top: 1.1rem;
    padding: 0;
    background: none;
    border: 0;
    cursor: pointer;
    font-family: var(--body);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    transition: color 0.25s;
  }
  .card-gallery::after {
    content: ' →';
  }
  .card-gallery:hover {
    color: var(--ivory);
  }
  @media (prefers-reduced-motion: reduce) {
    .card-header :global(img) {
      transition: none;
    }
  }
  @media (max-width: 940px) {
    .cards {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 640px) {
    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>
