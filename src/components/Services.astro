---
import { services } from '../data/services';
---

<section class="section" id="services">
  <div class="shell">
    <p class="eyebrow reveal">What we do</p>
    <h2 class="reveal">Whatever moves, we move it.</h2>
    <p class="lede reveal">
      A guest, a crew, an instrument, a patient — we plan it, drive it and stay
      reachable until it's done.
    </p>

    <div class="cards">
      {
        services.map((s) => (
          <article class="card reveal">
            <svg viewBox="0 0 24 24" aria-hidden="true" set:html={s.icon} />
            <h3>{s.title}</h3>
            <p>{s.text}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--hairline);
    border: 1px solid var(--hairline);
    margin-top: 3rem;
  }
  .card {
    background: var(--ink);
    padding: 2.2rem 1.9rem;
    position: relative;
    transition: background 0.3s;
  }
  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 1.9rem;
    width: 0;
    height: 2px;
    background: var(--gold);
    transition: width 0.35s ease;
  }
  .card:hover {
    background: var(--graphite);
  }
  .card:hover::before {
    width: 44px;
  }
  .card svg {
    width: 26px;
    height: 26px;
    stroke: var(--gold);
    fill: none;
    stroke-width: 1.1;
    margin-bottom: 1.3rem;
  }
  .card h3 {
    font-size: 1.45rem;
    margin-bottom: 0.7rem;
  }
  .card p {
    font-size: 15px;
    color: var(--stone);
  }
  @media (max-width: 940px) {
    .cards {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 640px) {
    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>
