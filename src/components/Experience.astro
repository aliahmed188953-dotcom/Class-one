---
import { Picture } from 'astro:assets';
import { images } from '../data/images';
---

<section class="exp">
  <div class="exp-bg" aria-hidden="true">
    <Picture
      src={images.experience.image}
      alt=""
      widths={[768, 1024, 1600].filter((w) => w <= images.experience.image.width)}
      sizes="100vw"
      formats={['avif', 'webp']}
      fallbackFormat="jpg"
      loading="lazy"
      decoding="async"
      style={`object-position:${images.experience.focal}`}
    />
  </div>
  <blockquote class="reveal">
    "The journey should feel like the destination."
    <cite>The Class One cabin standard</cite>
  </blockquote>
</section>

<style>
  .exp {
    position: relative;
    min-height: 52vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: clamp(5rem, 10vw, 8rem) var(--pad);
    background: var(--graphite);
    border-block: 1px solid var(--hairline);
    overflow: hidden;
  }
  /* Our own photography, served responsive — same scrim as the prototype. */
  .exp-bg {
    position: absolute;
    inset: 0;
  }
  .exp-bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .exp-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(rgba(10, 10, 11, 0.68), rgba(10, 10, 11, 0.78));
  }
  .exp blockquote {
    position: relative;
    z-index: 1;
    font-family: var(--display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(1.7rem, 4.4vw, 2.9rem);
    max-width: 22ch;
    line-height: 1.25;
  }
  .exp cite {
    display: block;
    font-family: var(--body);
    font-style: normal;
    font-size: 11px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
    margin-top: 1.6rem;
  }
</style>
