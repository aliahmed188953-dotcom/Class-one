---
import { Picture } from 'astro:assets';
import { images } from '../data/images';

// The real fleet (v3 photo library) — no stock imagery. Per-vehicle "View
// gallery" buttons open the shared page-level lightbox (see src/pages/index).
// Specs carried over from the approved design where the vehicle matches;
// TODO [TBD]: confirm guests/cases for the G-Class (no approved data yet).
const fleet = [
  {
    key: 'vclass',
    ...images.fleet.vclass,
    name: 'V-Class',
    model: 'Mercedes-Benz V-Class',
    specs: ['7 guests', '6 cases'],
  },
  {
    key: 'sclass',
    ...images.fleet.sclass,
    name: 'S-Class',
    model: 'Mercedes-Benz S-Class',
    specs: ['3 guests', '2 cases'],
  },
  {
    key: 'transporter',
    ...images.fleet.transporter,
    name: 'Premium Transporter',
    model: 'Starlight VIP lounge',
    specs: ['8 guests', 'Full luggage'],
  },
  {
    key: 'gclass',
    ...images.fleet.gclass,
    name: 'G-Class SUV',
    model: 'Mercedes-Benz G-Class',
    specs: [],
  },
];
---

<section class="section" id="fleet" style="padding-top:0">
  <div class="shell">
    <p class="eyebrow reveal">The fleet</p>
    <h2 class="reveal">Choose your cabin.</h2>

    <div class="fleet-grid">
      {
        fleet.map((car) => (
          <article class="fcar reveal">
            <div class="fcar-img">
              <Picture
                src={car.card.image}
                alt={car.card.alt}
                widths={[480, 800, 1200, 1600].filter(
                  (w) => w <= car.card.image.width
                )}
                sizes="(max-width: 760px) 100vw, 578px"
                formats={['avif', 'webp']}
                fallbackFormat="jpg"
                loading="lazy"
                decoding="async"
                style={car.card.focal ? `object-position:${car.card.focal}` : undefined}
              />
            </div>
            <div class="fcar-body">
              <span class="fcar-name">{car.name}</span>
              <span class="fcar-model">{car.model}</span>
              {car.specs.length > 0 && (
                <div class="fcar-specs">
                  {car.specs.map((s) => (
                    <span>{s}</span>
                  ))}
                </div>
              )}
              <button
                class="fcar-gallery"
                type="button"
                data-gallery={car.key}
                aria-label={`View ${car.name} gallery`}
              >
                View gallery
              </button>
            </div>
          </article>
        ))
      }

      <!-- CTA card — almost any vehicle, sourced on request. -->
      <article class="fcar fcar-cta reveal">
        <span class="fcar-name">Your car of choice</span>
        <p>
          Almost any vehicle, sourced on request — from executive sedans to
          something more exotic.
        </p>
        <a
          class="btn btn-sm"
          href="#book"
          data-prefill-vehicle="Other (on request)">Request a vehicle</a
        >
      </article>
    </div>
    <p class="fleet-note reveal">
      <b>Fixed, transparent rates</b> — quoted up front, confirmed before every
      journey. If your preferred car isn't listed, we source it — almost any
      vehicle on request.
    </p>
  </div>
</section>

<style>
  .fleet-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.6rem;
    margin-top: 3rem;
  }
  .fcar {
    border: 1px solid var(--hairline);
    background: var(--graphite);
  }
  .fcar-img {
    aspect-ratio: 16/10;
    overflow: hidden;
    position: relative;
  }
  /* :global so the rule also reaches the img rendered by <Picture>. */
  .fcar-img :global(img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    background-color: #17171a;
    transition: transform 0.6s ease;
  }
  .fcar:hover .fcar-img :global(img) {
    transform: scale(1.045);
  }
  .fcar-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 10, 11, 0.05) 40%,
      rgba(10, 10, 11, 0.55) 100%
    );
    pointer-events: none;
  }
  .fcar-body {
    padding: 1.5rem 1.7rem 1.7rem;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem 1.2rem;
    position: relative;
  }
  .fcar-name {
    font-family: var(--display);
    font-weight: 500;
    font-size: 1.7rem;
  }
  .fcar-model {
    color: var(--stone);
    font-size: 14px;
    letter-spacing: 0.04em;
  }
  .fcar-specs {
    display: flex;
    gap: 1.5rem;
    margin-top: 0.5rem;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--stone);
  }
  .fcar-specs,
  .fcar-gallery {
    width: 100%;
  }
  .fcar-gallery {
    margin-top: 0.6rem;
    padding: 0;
    background: none;
    border: 0;
    text-align: left;
    cursor: pointer;
    font-family: var(--body);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    transition: color 0.25s;
  }
  .fcar-gallery::after {
    content: ' →';
  }
  .fcar-gallery:hover {
    color: var(--ivory);
  }

  /* CTA card — gold hairline, no photo, centered, spans the full row. */
  .fcar-cta {
    grid-column: 1 / -1;
    border: 1px solid var(--gold);
    background: var(--ink);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1.1rem;
    padding: 2.6rem 2rem;
    min-height: 0;
  }
  .fcar-cta p {
    color: var(--stone);
    font-size: 15px;
    max-width: 34ch;
  }
  .fleet-note {
    margin-top: 1.8rem;
    font-size: 13.5px;
    color: var(--stone);
    letter-spacing: 0.04em;
  }
  .fleet-note b {
    color: var(--gold);
    font-weight: 400;
  }
  @media (max-width: 760px) {
    .fleet-grid {
      grid-template-columns: 1fr;
    }
    .fcar-cta {
      min-height: 0;
      padding: 2.4rem 1.5rem;
    }
  }
</style>
