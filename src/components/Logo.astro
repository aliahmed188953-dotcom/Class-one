---
/**
 * Numéro lockup — "Nº1" set in Cormorant Garamond 600, champagne gold.
 * U+00BA (º) carries the classic numéro underline natively in this font;
 * lining-nums raises the 1 to cap height beside the N.
 */
interface Props {
  href?: string;
}
const { href = '/' } = Astro.props;
---

<a href={href} class="lockup" aria-label="Class One Services — home">
  <span class="lgmark" aria-hidden="true">Nº1</span>
  <span class="lgtext"
    ><span class="l1">CLASS ONE</span><span class="l2">Services</span></span
  >
</a>

<style>
  .lockup {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .lgmark {
    font-family: var(--display);
    font-weight: 600;
    font-size: 36px;
    line-height: 1;
    color: var(--gold);
    font-variant-numeric: lining-nums;
    letter-spacing: 0.01em;
    flex: none;
    transform: translateY(-0.04em); /* optical centering against the text block */
  }
  .lgtext {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .lgtext .l1 {
    font-family: var(--display);
    font-weight: 600;
    font-size: 19px;
    letter-spacing: 0.14em;
  }
  .lgtext .l2 {
    font-size: 8.5px;
    letter-spacing: 0.52em;
    text-transform: uppercase;
    color: var(--stone);
    margin-top: 4px;
  }
</style>
