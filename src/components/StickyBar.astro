---
import { site, waLink } from '../data/site';
---

<!--
  Mobile quick-contact bar (<940px). Slides away while the booking card
  is in the viewport — the card already offers both actions there.
-->
<nav class="stickybar" id="stickyBar" aria-label="Quick contact">
  <a class="sb-call" href={`tel:${site.phoneE164}`}>Call — 24/7</a>
  <a class="sb-wa" href={waLink} target="_blank" rel="noopener">WhatsApp</a>
</nav>

<script>
  const bar = document.getElementById('stickyBar');
  if (bar) {
    const book = document.getElementById('book');
    if (book && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        ([en]) => bar.classList.toggle('show', !en.isIntersecting),
        { threshold: 0 }
      );
      io.observe(book);
    } else {
      // Pages without a booking card (legal, 404) keep the bar available.
      bar.classList.add('show');
    }
  }
</script>

<style>
  .stickybar {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 50; /* below the mobile menu (55) and header (60) */
    display: none;
    gap: 1px;
    background: var(--hairline);
    border-top: 1px solid var(--hairline);
    transform: translateY(100%);
    opacity: 0;
    visibility: hidden;
    transition:
      transform 0.3s ease,
      opacity 0.3s ease,
      visibility 0s 0.3s;
  }
  .stickybar.show {
    transform: none;
    opacity: 1;
    visibility: visible;
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }
  .stickybar a {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.05rem 0.5rem calc(1.05rem + env(safe-area-inset-bottom));
    background: rgba(10, 10, 11, 0.94);
    backdrop-filter: blur(10px);
    font-size: 12.5px;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ivory);
  }
  .stickybar .sb-wa {
    background: var(--gold);
    color: var(--ink);
    font-weight: 500;
  }
  @media (max-width: 940px) {
    .stickybar {
      display: flex;
    }
  }
</style>
